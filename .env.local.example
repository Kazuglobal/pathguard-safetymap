# VLM Analysis Configuration
# Set to "true" to use mock data for development (Edge Function not required)
# Set to "false" or remove for production (requires deployed Edge Function)
NEXT_PUBLIC_VLM_USE_MOCK=true

# 3D Route PoC (CesiumJS + Google Photorealistic 3D Tiles)
# Cesium Ion token: https://ion.cesium.com/tokens
NEXT_PUBLIC_CESIUM_ION_TOKEN=
# Google Maps API key (Map Tiles API を有効化すること)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# World Labs API (GSV → 3D Gaussian Splat)
# https://platform.worldlabs.ai/api-keys
WORLD_LABS_API_KEY=

# Instagram/TikTok AIエージェント (Anthropic)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Vercel Cron 認証シークレット（手動実行時も使用）
# openssl rand -base64 32 等で生成
CRON_SECRET=

# Sentry エラー監視
# https://sentry.io のプロジェクト設定から取得
SENTRY_DSN=
# Sentry 組織スラッグ (Settings > Organization)
SENTRY_ORG=
# Sentry プロジェクトスラッグ (Settings > Projects)
SENTRY_PROJECT=
# ソースマップアップロード用トークン (Vercel 環境変数のみ設定、ローカル不要)
# https://sentry.io/settings/auth-tokens/ で生成 (project:releases + org:read スコープ)
SENTRY_AUTH_TOKEN=
