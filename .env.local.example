# VLM Analysis Configuration
# Set to "true" to use mock data for development (Edge Function not required)
# Set to "false" or remove for production (requires deployed Edge Function)
NEXT_PUBLIC_VLM_USE_MOCK=true

# 3D Route PoC (CesiumJS + Google Photorealistic 3D Tiles)
# Cesium Ion token: https://ion.cesium.com/tokens
NEXT_PUBLIC_CESIUM_ION_TOKEN=
# Google Maps API key (Map Tiles API を有効化すること)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
