{
  "mcpServers": {
    "mapbox": {
      "command": "npx",
      "args": [
        "-y",
        "@mapbox/mcp-server"
      ],
      "env": {
        "MAPBOX_ACCESS_TOKEN": "REDACTED_MAPBOX_TOKEN"
      }
    },
    "sentry": {
      "command": "npx",
      "args": [
        "-y",
        "@sentry/mcp-server"
      ],
      "env": {
        "SENTRY_ACCESS_TOKEN": "REDACTED_SENTRY_ACCESS_TOKEN"
      }
    }
  }
}
